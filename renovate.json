{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:base",
    "group:allNonMajor",
    ":semanticCommitTypeAll(chore)",
    "helpers:pinGitHubActionDigests"
  ],
  "ignorePresets": [
    ":ignoreModulesAndTests"
  ],
  "semanticCommits": "enabled",
  "rangeStrategy": "bump",
  "prBodyTemplate": "# Motivation\n\nAutomated dependency update by Renovate bot.\n\n# Description\n\n{{{table}}}{{{notes}}}\n\n# Testing\n\nThis is an automated dependency update. No functional changes are expected.\n\n# Impact\n\n{{{changelogs}}}\n\n# Additional Information\n\n{{{warnings}}}{{{errors}}}{{{controls}}}This PR was generated automatically by [Renovate](https://docs.renovatebot.com/).",
  "packageRules": [
    {
      "groupName": "npm packages",
      "groupSlug": "npm",
      "matchDatasources": [
        "npm"
      ]
    },
    {
      "groupName": "nuget packages",
      "groupSlug": "nuget",
      "excludePackagePrefixes": [
        "Htc.Mock",
        "ArmoniK.Api",
        "ArmoniK.Utils"
      ],
      "matchDatasources": [
        "nuget"
      ],
      "bumpVersion": "patch"
    },
    {
      "groupName": "ArmoniK.Api",
      "groupSlug": "nuget-armonik-api",
      "matchPackagePrefixes": [
        "ArmoniK.Api"
      ],
      "matchDatasources": [
        "nuget"
      ],
      "bumpVersion": "patch"
    },
    {
      "groupName": "ArmoniK.Utils",
      "groupSlug": "nuget-armonik-utils",
      "matchPackagePrefixes": [
        "ArmoniK.Utils"
      ],
      "matchDatasources": [
        "nuget"
      ],
      "bumpVersion": "patch"
    },
    {
      "groupName": "Htc.Mock",
      "groupSlug": "nuget-htc-mock",
      "matchPackagePrefixes": [
        "Htc.Mock"
      ],
      "matchDatasources": [
        "nuget"
      ]
    },
    {
      "groupName": "docker images",
      "groupSlug": "docker",
      "matchDatasources": [
        "docker"
      ]
    },
    {
      "groupName": "terraform modules",
      "groupSlug": "terraform-module",
      "matchDatasources": [
        "terraform-module"
      ]
    },
    {
      "groupName": "terraform modules",
      "groupSlug": "terraform-provider",
      "matchDatasources": [
        "terraform-provider"
      ]
    },
    {
      "groupName": "github actions",
      "groupSlug": "github-actions",
      "matchDatasources": [
        "github-tags"
      ]
    }
  ]
}
